  "type": "commonjs",
  "devDependencies": {
    "@shelex/cypress-allure-plugin": "^2.41.2",
    "@types/node": "^25.5.0",
    "allure-commandline": "^2.24.0",
    "cypress": "^15.13.0",
    "mocha-allure-reporter": "^1.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  }
}